# ============================================================
# AI-News-Daily – Environment Variable Reference
# ============================================================
# Copy this file to .env for local development.
# In GitHub Actions, set these as Repository Secrets.
# NEVER commit your real .env file.
# ============================================================

# ── News Sources ─────────────────────────────────────────────
# Serper Google News API (https://serper.dev/)
SERPER_API_KEY=your_serper_api_key

# NewsAPI.org (https://newsapi.org/)
NEWS_API_KEY=your_news_api_key

# Optional: override default search query
# NEWS_QUERY=AI OR artificial intelligence OR technology

# ── LLM (OpenRouter) ─────────────────────────────────────────
# https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# ── Email (Gmail SMTP) ───────────────────────────────────────
# Gmail address used to send the digest
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your login password)
# Enable 2FA first, then generate at:
# https://myaccount.google.com/apppasswords
EMAIL_PASS=your_gmail_app_password

# Optional: separate recipient address (defaults to EMAIL_USER if unset)
# RECEIVER_EMAIL=recipient@example.com
